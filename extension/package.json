{
  "name": "@bili-syncplay/extension",
  "version": "1.2.4",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm --prefix ../packages/protocol run build",
    "build": "node scripts/build.mjs --target=chrome",
    "pretypecheck": "npm --prefix ../packages/protocol run build",
    "typecheck": "tsc -p tsconfig.json",
    "pretest": "npm --prefix ../packages/protocol run build",
    "test": "tsx --test test/**/*.test.ts",
    "coverage": "tsx --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-coverage-exclude='../packages/**' test/**/*.test.ts"
  },
  "dependencies": {
    "@bili-syncplay/protocol": "1.2.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
